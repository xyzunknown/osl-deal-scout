{
  "functions": {
    "api/index.js": {
      "includeFiles": "{data,public}/**"
    },
    "api/cron-digest.js": {
      "includeFiles": "data/**"
    }
  },
  "crons": [
    {
      "path": "/api/cron-digest",
      "schedule": "0 2 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/osl",
      "destination": "/api/index"
    },
    {
      "source": "/osl/:path*",
      "destination": "/api/index"
    }
  ]
}
